#!/usr/bin/env bash
# torch-review-log — atomically log a review result
# Usage: torch-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/torch-slug" 2>/dev/null)"
TORCH_HOME="${TORCH_HOME:-$HOME/.torch}"
mkdir -p "$TORCH_HOME/projects/$SLUG"

# Validate: input must be parseable JSON (reject malformed or injection attempts)
INPUT="$1"
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  # Not valid JSON — refuse to append
  echo "torch-review-log: invalid JSON, skipping" >&2
  exit 1
fi

echo "$INPUT" >> "$TORCH_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
